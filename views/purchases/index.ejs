<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Purchases - Olive Chairs ERP</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

  <style>
    .sticky-actions{
      position:sticky;
      top:0;
      z-index:1020;
      background:#fff;
      padding:.5rem 0;
    }

    .sticky-pagination{
      position:sticky;
      bottom:0;
      z-index:1010;
      background:#fff;
      padding:.5rem 0;
    }
  </style>
</head>

<body>

<%- include('../partials/navbar',{ user,activePage }) %>

<div class="container py-5">

  <!-- Header -->
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h3>Purchases</h3>

    <a href="/purchasing/purchases/new" class="btn btn-outline-primary">
      + Add Purchase
    </a>
  </div>

  <!-- Filter Bar -->
  <div class="sticky-actions d-flex justify-content-between align-items-center mb-3">

    <!-- Per Page -->
    <form class="d-flex align-items-center gap-2" method="get">
      <span class="small">Per page</span>

      <input type="hidden" name="search" value="<%= query.search || '' %>">
      <input type="hidden" name="page" value="1">

      <select
        name="limit"
        class="form-select form-select-sm"
        style="width:auto;min-width:80px"
        onchange="this.form.submit()"
      >
        <option value="10"  <%= +limit===10 ? 'selected' : '' %>>10</option>
        <option value="25"  <%= +limit===25 ? 'selected' : '' %>>25</option>
        <option value="50"  <%= +limit===50 ? 'selected' : '' %>>50</option>
        <option value="100" <%= +limit===100 ? 'selected' : '' %>>100</option>
      </select>
    </form>

    <!-- Search -->
    <form method="get" class="d-flex gap-2">
      <input
        name="search"
        class="form-control form-control-sm"
        placeholder="Search purchase..."
        value="<%= query.search || '' %>"
        style="width:220px"
      >

      <input type="hidden" name="limit" value="<%= limit %>">

      <button class="btn btn-sm btn-primary">Search</button>
    </form>

  </div>

  <div class="card shadow-sm">
    <div class="card-body">

    <% if(purchases && purchases.length>0){ %>

      <div class="table-responsive">

        <table class="table table-sm table-hover align-middle">

          <thead class="table-light">
            <tr>
              <th>#</th>
              <th>Purchase No</th>
              <th>Date</th>
              <th>Vendor</th>
              <th>Invoice</th>
              <th>Total</th>
              <th>Status</th>
              <th>Created At</th>
              <th>Created By</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>

          <tbody>

          <% purchases.forEach((p,index)=>{ %>

            <tr>

              <td><%= (page-1)*limit + index + 1 %></td>

              <td><%= p.purchaseNumber %></td>

              <td>
                <%= new Date(p.purchaseDate).toLocaleDateString('en-IN',{
                  day:'2-digit',
                  month:'2-digit',
                  year:'numeric'
                }) %>
              </td>

              <td><%= p.vendor?.name || '-' %></td>

              <td><%= p.invoiceNumber || '-' %></td>

              <td>₹<%= p.totalAmount.toFixed(2) %></td>

              <td>
                <span class="badge 
                  <%= p.status==='PURCHASED' ? 'bg-success' :
                      p.status==='CANCELLED' ? 'bg-danger' :
                      p.status==='DRAFT' ? 'bg-warning text-dark' :
                      'bg-secondary' %>">
                  <%= p.status %>
                </span>
              </td>

              <td class="text-nowrap">
                <%= new Date(p.createdAt).toLocaleDateString('en-IN',{
                  day:'2-digit',
                  month:'2-digit',
                  year:'numeric'
                }) %>
              </td>

              <td><%= p.createdBy?.fullName %></td>

              <td class="text-end">

                <a
                  href="/purchasing/purchases/<%= p._id %>"
                  class="btn btn-sm btn-outline-success"
                >
                  View
                </a>

                <a
                  href="/purchasing/purchases/<%= p._id %>/edit"
                  class="btn btn-sm btn-outline-primary"
                >
                  Edit
                </a>

                <button
                  type="button"
                  class="btn btn-sm btn-outline-danger"
                  data-bs-toggle="modal"
                  data-bs-target="#deleteModal"
                  data-id="<%= p._id %>"
                  data-name="<%= p.purchaseNumber %>"
                >
                  Delete
                </button>

              </td>

            </tr>

          <% }) %>

          </tbody>
        </table>

      </div>

      <!-- Pagination -->
      <div class="sticky-pagination mt-2">

        <nav>
          <ul class="pagination justify-content-center flex-nowrap">

            <%
            function buildQuery(pageNum){
              let qs=`?page=${pageNum}&limit=${limit}`;
              if(query.search) qs+=`&search=${encodeURIComponent(query.search)}`;
              return qs;
            }
            %>

            <!-- Previous -->
            <li class="page-item <%= page===1?'disabled':'' %>">
              <a class="page-link" href="<%= buildQuery(Math.max(1,page-1)) %>">&laquo;</a>
            </li>

            <!-- First -->
            <li class="page-item <%= page===1?'active':'' %>">
              <a class="page-link" href="<%= buildQuery(1) %>">1</a>
            </li>

            <%
            const slots=3;
            let centerStart=page-1;
            let centerEnd=page+1;

            if(centerStart<2){
              centerStart=2;
              centerEnd=centerStart+slots-1;
            }

            if(centerEnd>totalPages-1){
              centerEnd=totalPages-1;
              centerStart=centerEnd-slots+1;
            }

            centerStart=Math.max(2,centerStart);
            centerEnd=Math.min(totalPages-1,centerEnd);
            %>

            <% if(centerStart>2){ %>
              <li class="page-item disabled"><span class="page-link">…</span></li>
            <% } %>

            <% for(let p=centerStart;p<=centerEnd;p++){ %>
              <li class="page-item <%= p===page?'active':'' %>">
                <a class="page-link" href="<%= buildQuery(p) %>"><%= p %></a>
              </li>
            <% } %>

            <% if(centerEnd<totalPages-1){ %>
              <li class="page-item disabled"><span class="page-link">…</span></li>
            <% } %>

            <% if(totalPages>1){ %>
              <li class="page-item <%= page===totalPages?'active':'' %>">
                <a class="page-link" href="<%= buildQuery(totalPages) %>"><%= totalPages %></a>
              </li>
            <% } %>

            <!-- Next -->
            <li class="page-item <%= page===totalPages?'disabled':'' %>">
              <a class="page-link" href="<%= buildQuery(Math.min(totalPages,page+1)) %>">&raquo;</a>
            </li>

          </ul>
        </nav>

      </div>

    <% } else { %>

      <p class="text-muted text-center mb-0">No purchases found.</p>

    <% } %>

    </div>
  </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">

      <form id="deleteForm" method="POST">

        <div class="modal-header">
          <h5 class="modal-title">Confirm Delete</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <div class="modal-body">
          <p>
            Are you sure you want to delete purchase
            <strong id="deleteName"></strong>?
          </p>
        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            Cancel
          </button>

          <button type="submit" class="btn btn-danger">
            Yes, Delete
          </button>
        </div>

      </form>

    </div>
  </div>
</div>

<script>

  const deleteModal=document.getElementById('deleteModal');
  const deleteForm=document.getElementById('deleteForm');
  const deleteName=document.getElementById('deleteName');

  deleteModal.addEventListener('show.bs.modal',event=>{
    const button=event.relatedTarget;

    const id=button.getAttribute('data-id');
    const name=button.getAttribute('data-name');

    deleteForm.action=`/purchasing/purchases/${id}/delete`;
    deleteName.textContent=name;
  });

</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>