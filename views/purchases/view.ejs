<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>Purchase Detail</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<%- include('../partials/navbar', { user, activePage }) %>

<div class="container py-5">

  <!-- 🔷 HEADER -->
  <div class="card shadow-sm mb-4">
    <div class="card-body">

      <div class="d-flex justify-content-between align-items-center">
        <h4 class="mb-0">
          <%= purchase.purchaseNumber %>
        </h4>

        <span class="badge 
          <%= purchase.status==='PURCHASED' ? 'bg-success' :
              purchase.status==='CANCELLED' ? 'bg-danger' :
              purchase.status==='DRAFT' ? 'bg-warning text-dark' :
              'bg-secondary' %>">
          <%= purchase.status %>
        </span>
      </div>

      <div class="row g-3 mt-2">

        <div class="col-md-3">
          <small class="text-muted">Created By</small>
          <div>
            <%= purchase.createdBy?.fullName || '-' %>
          </div>
        </div>

        <div class="col-md-3">
          <small class="text-muted">Created At</small>
          <div>
            <%= new Date(purchase.createdAt).toLocaleString('en-IN', {
                timeZone: 'Asia/Kolkata',
                day: '2-digit',
                month: '2-digit',
                year: 'numeric',
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit',
                hour12: true
              }).replace('am', 'AM').replace('pm', 'PM') 
            %>
          </div>
        </div>

        <div class="col-md-3">
          <small class="text-muted">Updated By</small>
          <div>
            <%= purchase.updatedBy?.fullName || '-' %>
          </div>
        </div>

        <div class="col-md-3">
          <small class="text-muted">Updated At</small>
          <div>
            <%= purchase.updatedAt 
                  ? new Date(purchase.updatedAt).toLocaleString('en-IN', {
                      timeZone: 'Asia/Kolkata',
                      day: '2-digit',
                      month: '2-digit',
                      year: 'numeric',
                      hour: '2-digit',
                      minute: '2-digit',
                      second: '2-digit',
                      hour12: true
                    }).replace('am', 'AM').replace('pm', 'PM')
                  : '-' %>
          </div>
        </div>

      </div>

      <hr>

      <div class="row g-3">

        <div class="col-md-3">
          <small class="text-muted">Vendor</small>
          <div class="fw-semibold"><%= purchase.vendor?.name || '-' %></div>
        </div>

        <div class="col-md-3">
          <small class="text-muted">Invoice</small>
          <div><%= purchase.invoiceNumber || '-' %></div>
        </div>

        <div class="col-md-3">
          <small class="text-muted">Purchase Date</small>
          <div>
            <%= new Date(purchase.purchaseDate).toLocaleDateString('en-IN',{
              day: '2-digit',
              month: '2-digit',
              year: 'numeric'
            }) %>
          </div>
        </div>

        <div class="col-md-3">
          <small class="text-muted">Total Amount</small>
          <div class="fw-bold text-success">
            ₹<%= purchase.totalAmount.toFixed(2) %>
          </div>
        </div>

      </div>

    </div>
  </div>

  <!-- 🔷 ITEMS TABLE -->
  <div class="card shadow-sm mb-4">
  <div class="card-body">

    <h5 class="mb-3">Purchase Items</h5>

    <div class="table-responsive">
      <table class="table table-bordered table-sm align-middle">

        <thead class="table-light">
          <tr>
            <th>Type</th>
            <th>Item</th>
            <th>Category</th>
            <th>Color</th>
            <th>Qty</th>
            <th>Base</th>
            <th>Rate</th>
            <th>GST</th>
            <th>Total</th>
          </tr>
        </thead>

        <tbody>
          <% purchase.items.forEach(item => { %>
            <tr>

              <td>
                <span class="badge <%= item.itemType === 'chair' ? 'bg-primary' : 'bg-secondary' %>">
                  <%= item.itemType === 'chair' ? 'Chair' : 'Spare' %>
                </span>
              </td>

              <td>
                <%= item.itemType === 'chair'
                  ? item.chair?.modelName
                  : item.sparePart?.partName %>
              </td>

              <td>
                <% if(item.itemType === 'sparePart') { %>
                  <%= item.sparePart?.category?.name || '-' %>
                <% } else { %> - <% } %>
              </td>

              <td>
                <% 
                  let colorName = '-';
                  if (item.itemType === 'chair' && item.chair?.colors) {
                    const found = item.chair.colors.find(
                      c => c._id.toString() === item.chairColor?.toString()
                    );
                    if (found) colorName = found.name;
                  }
                %>
                <%= colorName %>
              </td>

              <td><%= item.quantity %></td>
              <td>₹<%= item.basePrice.toFixed(2) %></td>
              <td>₹<%= item.finalRate.toFixed(2) %></td>

              <td>
                <% if(item.gstApplicable) { %>
                  <span class="badge bg-info text-white">18% GST</span>
                <% } else { %>
                  <span class="badge bg-secondary">No GST</span>
                <% } %>
              </td>

              <td class="fw-bold text-success">
                ₹<%= item.totalCost.toFixed(2) %>
              </td>

            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <div class="d-flex justify-content-end mt-3">
      <div style="min-width: 260px;">

        <table class="table table-sm mb-0">

          <tr>
            <td class="text-muted">Items</td>
            <td class="text-end fw-semibold">
              <%= purchase.items.length %>
            </td>
          </tr>

          <tr>
            <td class="text-muted">Total</td>
            <td class="text-end fw-bold text-success">
              ₹<%= purchase.totalAmount.toFixed(2) %>
            </td>
          </tr>

        </table>

      </div>
    </div>
  </div>
</div>

  <!-- 🔷 NOTES -->
  <div class="card shadow-sm mb-4">
    <div class="card-body">

      <h5 class="mb-3">Notes</h5>

      <% if(purchase.notes) { %>
        <div class="border rounded p-3 bg-light">
          <%= purchase.notes %>
        </div>
      <% } else { %>
        <p class="text-muted">No notes added.</p>
      <% } %>

    </div>
  </div>

  <!-- 🔷 ACTIONS -->
  <div class="d-flex justify-content-end gap-2">

    <a href="/purchasing/purchases/<%= purchase._id %>/edit" 
       class="btn btn-primary">
      Edit Purchase
    </a>

  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>