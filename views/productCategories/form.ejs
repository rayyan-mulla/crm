<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= mode === 'create' ? 'Add Product Category' : 'Edit Product Category' %> - Olive Chairs ERP</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>
<body>
<%- include('../partials/navbar', { user, activePage }) %>

<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3><%= mode === 'create' ? 'Add Product Category' : 'Edit Product Category' %></h3>
  </div>

  <form action="<%= mode === 'create' ? '/production/product-categories' : '/production/product-categories/' + category._id %>" method="post" class="card shadow-sm p-3">
    <div class="card-body">
      <div class="row g-3">
        <!-- Category Name -->
        <div class="col-md-8">
          <label class="form-label">Category Name</label>
          <input name="name" class="form-control" required value="<%= category.name || '' %>" placeholder="Chair, Sofa, Table, Desk" />
        </div>

        <!-- Active Checkbox -->
        <div class="col-md-4 d-flex align-items-end">
          <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" name="isActive" id="isActive" <%= mode === 'create' ? 'checked' : (category.isActive ? 'checked' : '') %> />
            <label class="form-check-label" for="isActive">Active</label>
          </div>
        </div>
      </div>

      <div class="mt-4 d-flex justify-content-end">
        <button class="btn btn-primary"><%= mode === 'create' ? 'Create' : 'Save Changes' %></button>
      </div>
    </div>
  </form>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>