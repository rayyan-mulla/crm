<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Sub Assemblies - Olive Chairs ERP</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
  <style>
    .sticky-actions {
      position: sticky;
      top: 0;
      z-index: 1020;
      background: #fff;
      padding: .5rem 0;
    }
    .sticky-pagination {
      position: sticky;
      bottom: 0;
      z-index: 1010;
      background: #fff;
      padding: .5rem 0;
    }
  </style>
</head>
<body>
  <%- include('../partials/navbar', { user, activePage }) %>

  <div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h3>Sub Assemblies</h3>
      <a href="/production/sub-assemblies/new" class="btn btn-outline-primary">+ Add Sub Assembly</a>
    </div>

    <div class="sticky-actions d-flex justify-content-between align-items-center mb-3">
      <form class="d-flex align-items-center gap-2" method="get">
        <span class="small">Per page</span>
        <input type="hidden" name="search" value="<%= query.search || '' %>">
        <input type="hidden" name="page" value="1">
        <select name="limit" class="form-select form-select-sm" style="width:auto; min-width:80px;" onchange="this.form.submit()">
          <option value="10"  <%= +limit === 10  ? 'selected' : '' %>>10</option>
          <option value="25"  <%= +limit === 25  ? 'selected' : '' %>>25</option>
          <option value="50"  <%= +limit === 50  ? 'selected' : '' %>>50</option>
          <option value="100" <%= +limit === 100 ? 'selected' : '' %>>100</option>
        </select>
      </form>

      <form method="get" class="d-flex gap-2">
        <input name="search" class="form-control form-control-sm" placeholder="Search..." value="<%= query.search || '' %>" style="width:220px">
        <input type="hidden" name="limit" value="<%= limit %>">
        <button class="btn btn-sm btn-primary">Search</button>
      </form>
    </div>

    <div class="card shadow-sm">
      <div class="card-body">
        <% if(subAssemblies && subAssemblies.length){ %>
          <div class="table-responsive">
            <table class="table table-sm table-hover align-middle">
              <thead class="table-light">
                <tr>
                  <th style="width:40px;">#</th>
                  <th>Name</th>
                  <th>Code</th>
                  <th>Components Breakdown</th>
                  <th class="text-center" style="width:90px;">Stock</th>
                  <th>Cost</th>
                  <th class="text-center" style="width:70px;">GST</th>
                  <th style="width:100px;">Status</th>
                  <th style="width:120px;">Created At</th>
                  <th style="width:140px;" class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% subAssemblies.forEach((sa, index) => { %>
                  <tr>
                    <td><%= (page - 1) * limit + index + 1 %></td>
                    <td>
                      <span class="fw-semibold"><%= sa.name %></span>
                    </td>
                    <td class="text-nowrap">
                      <span class="badge bg-light text-dark border">
                        <%= sa.code || '-' %>
                      </span>
                    </td>
                    <td>
                      <% if(sa.components?.length){ %>
                        <div class="d-flex flex-wrap gap-1">
                          <% sa.components.forEach(c => { %>
                            <div class="badge bg-light text-dark border d-flex align-items-center gap-2 px-2 py-1" style="font-weight: normal;">
                              <span><%= c.item?.partName || '-' %></span>
                              <span class="badge bg-secondary text-white rounded-pill px-1.5 py-0.5" style="font-size: 0.75rem;">
                                ×<%= c.quantity %>
                              </span>
                            </div>
                          <% }) %>
                        </div>
                      <% } else { %>
                        <span class="text-muted small">—</span>
                      <% } %>
                    </td>
                    
                    <!-- Dynamic Color-Coded Stock Status Tracking -->
                    <%
                      let stockClass = 'bg-success';
                      let currentStock = sa.stock || 0;
                      if (currentStock === 0) stockClass = 'bg-danger';
                      else if (currentStock < 10) stockClass = 'bg-warning text-dark';
                    %>
                    <td class="text-center">
                      <span class="badge <%= stockClass %>">
                        <%= currentStock %>
                      </span>
                    </td>

                    <!-- Consolidated Pricing Stack Tracking -->
                    <td>
                      <div class="d-flex flex-column gap-0" style="min-width: 130px;">
                        <div class="d-flex justify-content-between small">
                          <span class="text-muted">BOM:</span>
                          <span>₹<%= (sa.bomCost || 0).toFixed(2) %></span>
                        </div>
                        <div class="d-flex justify-content-between small">
                          <span class="text-muted">Base:</span>
                          <span>₹<%= (sa.basePrice || 0).toFixed(2) %></span>
                        </div>
                        <div class="d-flex justify-content-between small fw-bold border-top pt-1 mt-1">
                          <span class="text-muted">Final:</span>
                          <span class="text-primary">₹<%= (sa.finalPrice || 0).toFixed(2) %></span>
                        </div>
                      </div>
                    </td>

                    <!-- Tax Metrics Indicator -->
                    <td class="text-center">
                      <% if (sa.gstApplicable !== false) { %>
                        <span class="badge bg-info text-white" style="font-size: 0.65rem; padding: 0.35em 0.5em;">
                          18%
                        </span>
                      <% } else { %>
                        <span class="text-muted small">—</span>
                      <% } %>
                    </td>

                    <td>
                      <span class="badge <%= sa.isActive ? 'bg-success' : 'bg-secondary' %>">
                        <%= sa.isActive ? 'Active' : 'Inactive' %>
                      </span>
                    </td>
                    <td class="text-nowrap">
                      <%= new Date(sa.createdAt).toLocaleDateString('en-IN', {
                        day: '2-digit',
                        month: '2-digit',
                        year: 'numeric'
                      }) %>
                    </td>
                    <td>
                      <div class="d-flex gap-1 justify-content-end">
                        <a href="/production/sub-assemblies/<%= sa._id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
                        <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#deleteModal" data-id="<%= sa._id %>" data-name="<%= sa.name %>">
                          Delete
                        </button>
                      </div>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>

          <div class="sticky-pagination mt-2">
            <nav aria-label="report-pagination">
              <ul class="pagination justify-content-center flex-nowrap">
                <%
                  function buildQuery(pageNum) {
                    let qs = `?page=${pageNum}&limit=${limit}`;
                    if (query.search) qs += `&search=${encodeURIComponent(query.search)}`;
                    return qs;
                  }
                %>
                <li class="page-item <%= page === 1 ? 'disabled' : '' %>">
                  <a class="page-link" href="<%= buildQuery(Math.max(1, page - 1)) %>">&laquo;</a>
                </li>

                <li class="page-item <%= page === 1 ? 'active' : '' %>">
                  <a class="page-link" href="<%= buildQuery(1) %>">1</a>
                </li>

                <%
                  const slots = 3;
                  let centerStart = page - 1;
                  let centerEnd   = page + 1;

                  if (centerStart < 2) {
                    centerStart = 2;
                    centerEnd = centerStart + slots - 1;
                  }
                  if (centerEnd > totalPages - 1) {
                    centerEnd = totalPages - 1;
                    centerStart = centerEnd - slots + 1;
                  }

                  centerStart = Math.max(2, centerStart);
                  centerEnd   = Math.min(totalPages - 1, centerEnd);
                %>

                <% if (centerStart > 2) { %>
                  <li class="page-item disabled"><span class="page-link">…</span></li>
                <% } %>

                <% for (let p = centerStart; p <= centerEnd; p++) { %>
                  <li class="page-item <%= p === page ? 'active' : '' %>">
                    <a class="page-link" href="<%= buildQuery(p) %>"><%= p %></a>
                  </li>
                <% } %>

                <% if (centerEnd < totalPages - 1) { %>
                  <li class="page-item disabled"><span class="page-link">…</span></li>
                <% } %>

                <% if (totalPages > 1) { %>
                  <li class="page-item <%= page === totalPages ? 'active' : '' %>">
                    <a class="page-link" href="<%= buildQuery(totalPages) %>"><%= totalPages %></a>
                  </li>
                <% } %>

                <li class="page-item <%= page === totalPages ? 'disabled' : '' %>">
                  <a class="page-link" href="<%= buildQuery(Math.min(totalPages, page + 1)) %>">&raquo;</a>
                </li>
              </ul>
            </nav>
          </div>
        <% } else { %>
          <div class="text-center text-muted py-3">No sub assemblies found</div>
        <% } %>
      </div>
    </div>
  </div>

  <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <form id="deleteForm" method="POST">
          <div class="modal-header">
            <h5 class="modal-title">Confirm Delete</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p>Are you sure you want to delete sub assembly <strong id="deleteSubAssemblyName"></strong>?</p>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-danger">Yes, Delete</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    const deleteModal = document.getElementById('deleteModal');
    const deleteForm = document.getElementById('deleteForm');
    const deleteSubAssemblyName = document.getElementById('deleteSubAssemblyName');

    deleteModal.addEventListener('show.bs.modal', event => {
      const button = event.relatedTarget;
      const id = button.getAttribute('data-id');
      const name = button.getAttribute('data-name');

      deleteForm.action = `/production/sub-assemblies/${id}/delete`;
      deleteSubAssemblyName.textContent = name;
    });
  </script>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>