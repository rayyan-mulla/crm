<style>
  /* Navbar logo styling */
  .navbar-brand img {
    height: 50px; /* adjust as needed */
    width: auto;
  }

  /* Centered brand text */
  .navbar-center {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    white-space: nowrap;
  }

  /* Back button styling */
  .back-btn {
    color: #6c757d; /* Bootstrap secondary grey */
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .back-btn:hover {
    color: #000000 !important; /* Turn black on hover */
  }

  /* Fluid typography for middle branding segment */
  .crm-title {
    font-size: 1.1rem;
    white-space: nowrap;
    text-align: center;
  }

  /* Responsive adjust for mid-range desktop breakpoints */
  @media (max-width: 1200px) and (min-width: 992px) {
    .crm-title {
      font-size: 0.9rem;
    }
  }

  @media (max-width: 992px) {
    .crm-title {
      font-size: 14px;
      text-align: left;
    }
  }
</style>

<nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm sticky-top">
  <div class="container-fluid position-relative">

    <!-- Logo on the left -->
    <a class="navbar-brand" href="/">
      <img src="/images/logo.png" alt="Olive Chairs Logo">
    </a>

    <!-- Back Button (only if showBack is true) -->
    <% if (typeof showBack !== 'undefined' && showBack) { %>
      <a
        href="/leads"
        id="navBackBtn"
        class="back-btn ms-2 d-flex align-items-center text-decoration-none"
      >
        <span class="d-none d-md-inline">&larr; Back</span>
      </a>
    <% } %>

    <!-- Centered CRM text: Flexible column width structure prevents collisions -->
    <div class="crm-title fw-bold px-3 flex-grow-1 d-none d-sm-block text-center text-lg-center">
      <span class="d-lg-none">CRM</span>
      <span class="d-none d-lg-inline">Customer Relationship Management</span>
    </div>

    <!-- Mobile toggle -->
    <button
      class="navbar-toggler"
      type="button"
      data-bs-toggle="collapse"
      data-bs-target="#navbarNav"
    >
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- Links on the right -->
    <div class="collapse navbar-collapse justify-content-end" id="navbarNav">
      <ul class="navbar-nav">

        <!-- Leads Dropdown -->
        <li class="nav-item dropdown">
          <a
            class="nav-link dropdown-toggle 
              <%= (activePage === 'dashboard' || activePage === 'leads' || activePage === 'reports') ? 'active' : '' %>"
            href="#"
            role="button"
            data-bs-toggle="dropdown"
          >
            Leads
          </a>

          <ul class="dropdown-menu">
            <li>
              <a
                class="dropdown-item <%= (activePage === 'dashboard') ? 'active' : '' %>"
                href="/"
              >
                Dashboard
              </a>
            </li>

            <li>
              <a
                class="dropdown-item <%= (activePage === 'leads') ? 'active' : '' %>"
                href="/leads"
              >
                Leads
              </a>
            </li>

            <li>
              <a
                class="dropdown-item <%= (activePage === 'reports') ? 'active' : '' %>"
                href="/reports"
              >
                Reports
              </a>
            </li>
          </ul>
        </li>

        <% if (user && user.role === 'admin') { %>

          <!-- Raw Materials Dropdown -->
          <li class="nav-item dropdown">
            <a
              class="nav-link dropdown-toggle
                <%= (activePage === 'chairs' || activePage === 'spareParts' || activePage === 'sparePartCategories') ? 'active' : '' %>"
              href="#"
              role="button"
              data-bs-toggle="dropdown"
            >
              Raw Materials
            </a>

            <ul class="dropdown-menu">
              <li>
                <a
                  class="dropdown-item <%= (activePage === 'chairs') ? 'active' : '' %>"
                  href="/raw-materials/chairs"
                >
                  Chairs
                </a>
              </li>

              <li>
                <a
                  class="dropdown-item <%= (activePage === 'spareParts') ? 'active' : '' %>"
                  href="/raw-materials/spare-parts"
                >
                  Spare Parts
                </a>
              </li>

              <li>
                <a
                  class="dropdown-item <%= (activePage === 'sparePartCategories') ? 'active' : '' %>"
                  href="/raw-materials/spare-part-categories"
                >
                  Spare Part Categories
                </a>
              </li>
            </ul>
          </li>

          <!-- Production Dropdown -->
          <li class="nav-item dropdown">
            <a
              class="nav-link dropdown-toggle
                <%= (activePage === 'productCategories' || activePage === 'subAssemblies' || activePage === 'products' || activePage === 'productionEntry') ? 'active' : '' %>"
              href="#"
              role="button"
              data-bs-toggle="dropdown"
            >
              Production
            </a>

            <ul class="dropdown-menu">
              <li>
                <a
                  class="dropdown-item <%= (activePage === 'productCategories') ? 'active' : '' %>"
                  href="/production/product-categories"
                >
                  Product Categories
                </a>
              </li>
              <li>
                <a
                  class="dropdown-item <%= (activePage === 'subAssemblies') ? 'active' : '' %>"
                  href="/production/sub-assemblies"
                >
                  Sub Assemblies
                </a>
              </li>
              <li>
                <a
                  class="dropdown-item <%= (activePage === 'products') ? 'active' : '' %>"
                  href="/production/products"
                >
                  Products
                </a>
              </li>
              <li>
                <a
                  class="dropdown-item <%= (activePage === 'productionEntry') ? 'active' : '' %>"
                  href="/production/productions"
                >
                  Productions
                </a>
              </li>
            </ul>
          </li>

          <!-- Purchasing Dropdown -->
          <li class="nav-item dropdown">
            <a
              class="nav-link dropdown-toggle
                <%= (activePage === 'vendors' || activePage === 'purchases' || activePage === 'vendorPayments') ? 'active' : '' %>"
              href="#"
              role="button"
              data-bs-toggle="dropdown"
            >
              Purchasing
            </a>

            <ul class="dropdown-menu">
              <li>
                <a
                  class="dropdown-item <%= (activePage === 'vendors') ? 'active' : '' %>"
                  href="/purchasing/vendors"
                >
                  Vendors
                </a>
              </li>

              <li>
                <a
                  class="dropdown-item <%= (activePage === 'purchases') ? 'active' : '' %>"
                  href="/purchasing/purchases"
                >
                  Purchases
                </a>
              </li>
              <li>
                <a
                  class="dropdown-item <%= (activePage === 'vendorPayments') ? 'active' : '' %>"
                  href="/purchasing/vendor-payments"
                >
                  Vendor Payments
                </a>
              </li>
            </ul>
          </li>

          <!-- Users -->
          <li class="nav-item">
            <a
              class="nav-link <%= (activePage === 'users') ? 'active' : '' %>"
              href="/users"
            >
              Users
            </a>
          </li>

        <% } %>

        <!-- Profile Dropdown -->
          <% if (user) { %>
          <li class="nav-item dropdown">
            <a
              class="nav-link dropdown-toggle d-flex align-items-center"
              href="#"
              role="button"
              data-bs-toggle="dropdown"
            >
              <i class="bi bi-person-circle me-1"></i>
              <span><%= user.fullName %> (<%= user.role %>)</span>
            </a>

            <ul class="dropdown-menu dropdown-menu-end">
              <li>
                <span class="dropdown-item-text">
                  Signed in as <strong><%= user.username %></strong>
                </span>
              </li>

              <li><hr class="dropdown-divider"></li>

              <li>
                <a class="dropdown-item text-danger" href="/auth/logout">
                  Logout
                </a>
              </li>
            </ul>
          </li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>

<script>
  (function () {
    const backBtn = document.getElementById("navBackBtn");
    if (!backBtn) return;

    function getSavedLeadsUrl() {
      try {
        return sessionStorage.getItem("leadsLastUrl");
      } catch {
        return null;
      }
    }

    function pickFallback() {
      try {
        const ref = document.referrer;
        if (ref && new URL(ref).origin === location.origin) {
          return ref;
        }
      } catch {}

      return getSavedLeadsUrl() || "/leads";
    }

    function smartBack() {
      try {
        if (history.length > 1 && document.referrer.includes(location.origin)) {
          history.back();
          return;
        }
        location.href = pickFallback();
      } catch {
        location.href = "/leads";
      }
    }

    document.addEventListener("DOMContentLoaded", () => {
      backBtn.href = pickFallback(); // enables long-press open-in-new-tab
      backBtn.addEventListener("click", (e) => {
        e.preventDefault();
        smartBack();
      });
    });
  })();
</script>