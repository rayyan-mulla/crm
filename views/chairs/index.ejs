<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>Chairs - Olive Chairs CRM</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <style>
      .sticky-actions {
        position: sticky;
        top: 0;
        z-index: 1020;
        background: #fff;
        padding: .5rem 0;
      }

      .sticky-pagination {
        position: sticky;
        bottom: 0;
        z-index: 1010;
        background: #fff;
        padding: .5rem 0;
      }
    </style>
  </head>
  <body>
    <%- include('../partials/navbar', { user, activePage }) %>
    <div class="container py-5">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Chair Models</h3>
        <a href="/raw-materials/chairs/new" class="btn btn-outline-primary">+ Add Chair Model</a>
      </div>

      <div class="sticky-actions d-flex justify-content-between align-items-center mb-3">
        <form 
          id="limitForm"
          class="d-flex align-items-center gap-2"
          method="get"
        >
          <span class="small">Per page</span>

          <!-- Preserve current filters as hidden inputs -->
          <input type="hidden" name="search" value="<%= query.search || '' %>">

          <!-- When changing limit, usually makes sense to reset to page 1 -->
          <input type="hidden" name="page" value="1">

          <select 
            name="limit" 
            id="limitSelect" 
            class="form-select form-select-sm" 
            style="width:auto; min-width:80px;"
            onchange="this.form.submit()"
          >
            <option value="10"  <%= +limit === 10  ? 'selected' : '' %>>10</option>
            <option value="25"  <%= +limit === 25  ? 'selected' : '' %>>25</option>
            <option value="50"  <%= +limit === 50  ? 'selected' : '' %>>50</option>
            <option value="100" <%= +limit === 100 ? 'selected' : '' %>>100</option>
          </select>
        </form>


        <!-- Right: Seatch -->

        <form method="get" class="d-flex gap-2">
          <input
            name="search"
            class="form-control form-control-sm"
            placeholder="Search..."
            value="<%= query.search || '' %>"
            style="width:220px"
          >

          <input type="hidden" name="limit" value="<%= limit %>">

          <button class="btn btn-sm btn-primary">
            Search
          </button>
        </form>
      </div>

      <div class="card shadow-sm">
        <div class="card-body">
          <% if (chairs && chairs.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-sm table-hover align-middle">
                <thead class="table-light">
                  <tr>
                    <th style="width: 40px;">#</th>
                    <th style="max-width: 150px;">Model</th>
                    <th style="width: 120px;">HSN Code</th> 
                    <th style="max-width: 250px;">Colors</th>
                    <th style="width: 100px;">Status</th>
                    <th style="width: 120px;">Created At</th>
                    <th style="width: 140px;" class="text-end">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% chairs.forEach((chair, index) => { %>
                    <tr>
                      <td><%= (page-1)*limit + index + 1 %></td>
                      <td class="text-truncate" style="max-width:150px;" title="<%= chair.modelName %>">
                        <%= chair.modelName %>
                      </td>
                      <td class="text-nowrap">
                        <span class="badge bg-light text-dark border">
                          <%= chair.hsnCode || '94036000' %>
                        </span>
                      </td>
                      <td>
                        <% if (chair.colors && chair.colors.length) { %>
                          <div class="d-flex flex-wrap gap-2">
                            <% chair.colors.forEach(col => { %>
                              <div class="badge bg-white text-dark border p-2 shadow-sm" style="font-weight: normal; min-width: 140px;">
                                <div class="fw-bold border-bottom mb-1 pb-1 d-flex justify-content-between align-items-center">
                                  <span class="text-truncate" style="max-width: 80px;" title="<%= col.name %>">
                                    <%= col.name %>
                                  </span>
                                  <% if (col.gstApplicable) { %>
                                    <span class="badge bg-info text-white ms-2" style="font-size: 0.65rem; padding: 0.35em 0.5em;">
                                      18% GST
                                    </span>
                                  <% } %>
                                </div>
                                
                                <div class="d-flex flex-column gap-0">
                                  <div class="d-flex justify-content-between small">
                                    <span class="text-muted">Base:</span>
                                    <span>₹<%= col.basePrice %></span>
                                  </div>
                                  <div class="d-flex justify-content-between small fw-bold">
                                    <span class="text-muted">Final:</span>
                                    <span class="text-primary">₹<%= col.finalPrice ? col.finalPrice.toFixed(2) : col.basePrice.toFixed(2) %></span>
                                  </div>
                                </div>

                                <%
                                  const stock = Number(col.stock) || 0;

                                  let stockClass = 'bg-success';
                                  if (stock === 0) stockClass = 'bg-danger';
                                  else if (stock < 10) stockClass = 'bg-warning text-dark';
                                %>

                                <div class="d-flex justify-content-between small mt-1">
                                  <span class="text-muted">Stock:</span>
                                  <span class="badge <%= stockClass %>">
                                    <%= stock %>
                                  </span>
                                </div>
                                
                              </div>
                            <% }) %>
                          </div>
                        <% } else { %>
                          <span class="text-muted">—</span>
                        <% } %>
                      </td>
                      <td>
                        <span class="badge <%= chair.isActive ? 'bg-success' : 'bg-secondary' %>">
                          <%= chair.isActive ? 'Active' : 'Inactive' %>
                        </span>
                      </td>
                      <td class="text-nowrap">
                        <%= new Date(chair.createdAt).toLocaleDateString('en-IN',{
                          day: '2-digit',
                          month: '2-digit',
                          year: 'numeric'
                        }) %>
                      </td>
                      <td>
                        <div class="d-flex gap-1 flex-nowrap justify-content-end">
                          <a href="/raw-materials/chairs/<%= chair._id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>
                          <button 
                            type="button" 
                            class="btn btn-sm btn-outline-danger" 
                            data-bs-toggle="modal" 
                            data-bs-target="#deleteModal" 
                            data-chair-id="<%= chair._id %>"
                            data-chair-name="<%= chair.modelName %>">
                            Delete
                          </button>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>

            <!-- Pagination -->
            <div class="sticky-pagination mt-2">
              <nav aria-label="report-pagination">
                <ul class="pagination justify-content-center flex-nowrap">

                  <%
                    function buildQuery(pageNum) {
                      let qs = `?page=${pageNum}&limit=${limit}`;
                      if (query.search) qs += `&search=${encodeURIComponent(query.search)}`;
                      return qs;
                    }
                  %>
                  <!-- Previous -->
                  <li class="page-item <%= page === 1 ? 'disabled' : '' %>">
                    <a class="page-link" href="<%= buildQuery(Math.max(1, page - 1)) %>">&laquo;</a>
                  </li>

                  <!-- First -->
                  <li class="page-item <%= page === 1 ? 'active' : '' %>">
                    <a class="page-link" href="<%= buildQuery(1) %>">1</a>
                  </li>

                  <%
                    const slots = 3;
                    let centerStart = page - 1;
                    let centerEnd   = page + 1;

                    if (centerStart < 2) {
                      centerStart = 2;
                      centerEnd = centerStart + slots - 1;
                    }

                    if (centerEnd > totalPages - 1) {
                      centerEnd = totalPages - 1;
                      centerStart = centerEnd - slots + 1;
                    }

                    centerStart = Math.max(2, centerStart);
                    centerEnd   = Math.min(totalPages - 1, centerEnd);
                  %>

                  <!-- Left Ellipsis -->
                  <% if (centerStart > 2) { %>
                    <li class="page-item disabled">
                      <span class="page-link">…</span>
                    </li>
                  <% } %>

                  <!-- Center Pages -->
                  <% for (let p = centerStart; p <= centerEnd; p++) { %>
                    <li class="page-item <%= p === page ? 'active' : '' %>">
                      <a class="page-link" href="<%= buildQuery(p) %>"><%= p %></a>
                    </li>
                  <% } %>

                  <!-- Right Ellipsis -->
                  <% if (centerEnd < totalPages - 1) { %>
                    <li class="page-item disabled">
                      <span class="page-link">…</span>
                    </li>
                  <% } %>

                  <!-- Last -->
                  <% if (totalPages > 1) { %>
                    <li class="page-item <%= page === totalPages ? 'active' : '' %>">
                      <a class="page-link" href="<%= buildQuery(totalPages) %>"><%= totalPages %></a>
                    </li>
                  <% } %>

                  <!-- Next -->
                  <li class="page-item <%= page === totalPages ? 'disabled' : '' %>">
                    <a class="page-link" href="<%= buildQuery(Math.min(totalPages, page + 1)) %>">&raquo;</a>
                  </li>

                </ul>
              </nav>
            </div>
          <% } else { %>
            <p class="text-muted text-center mb-0">No chair models found.</p>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Delete Confirmation Modal -->
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <form id="deleteForm" method="POST">
            <div class="modal-header">
              <h5 class="modal-title">Confirm Delete</h5>
              <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
              <p>Are you sure you want to delete chair model <strong id="deleteChairName"></strong>?</p>
            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
              <button type="submit" class="btn btn-danger">Yes, Delete</button>
            </div>
          </form>
        </div>
      </div>
    </div>

    <script>
      const deleteModal = document.getElementById('deleteModal');
      const deleteForm = document.getElementById('deleteForm');
      const deleteChairName = document.getElementById('deleteChairName');

      deleteModal.addEventListener('show.bs.modal', event => {
        const button = event.relatedTarget;
        const chairId = button.getAttribute('data-chair-id');
        const chairName = button.getAttribute('data-chair-name');

        deleteForm.action = `/raw-materials/chairs/${chairId}/delete`; // update form action
        deleteChairName.textContent = chairName; // show chair name in modal
      });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
