<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title><%= mode === 'create' ? 'Add Chair Model' : 'Edit Chair Model' %> - Olive Chairs CRM</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
  <style>
    .color-row { background: #f8f9fa; border-radius: 8px; padding: 10px; }
  </style>
</head>
<body>
<%- include('../partials/navbar', { user, activePage }) %>

<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3><%= mode === 'create' ? 'Add Chair Model' : 'Edit Chair Model' %></h3>
    <!-- <a href="/chairs" class="btn btn-secondary">Back</a> -->
  </div>

  <form action="<%= mode === 'create' ? '/raw-materials/chairs' : '/raw-materials/chairs/' + chair._id %>" method="post" class="card shadow-sm p-3">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h5 class="mb-0">Chair Information</h5>
        <div class="form-check">
          <input class="form-check-input" type="checkbox" name="isActive" id="isActive"
            <%= (mode==='create' ? 'checked' : (chair.isActive ? 'checked' : '')) %> />
          <label class="form-check-label" for="isActive">Active</label>
        </div>
      </div>
      <div class="row g-3">
        <div class="col-md-4">
          <label class="form-label">Model Name</label>
          <input name="modelName" class="form-control" required value="<%= chair.modelName || '' %>"/>
        </div>
        <div class="col-md-4">
          <label class="form-label">Product Category</label>
          <select name="category" class="form-select" required>
            <option value="">Select Category</option>
            <% categories.forEach(cat => { %>
              <option value="<%= cat._id %>" <%= chair.category && chair.category.toString() === cat._id.toString() ? 'selected' : '' %>>
                <%= cat.name %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">HSN Code</label>
          <input name="hsnCode" class="form-control" value="<%= chair.hsnCode || '94036000' %>"/>
        </div>
      </div>

      <hr class="my-4"/>

      <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="mb-0">Colors & Base Prices</h5>
        <button type="button" id="addColor" class="btn btn-sm btn-outline-primary">Add Color</button>
      </div>

      <div id="colorsContainer" class="vstack gap-2">
        <% (chair.colors || []).forEach(function(col){ %>
          <div class="color-row row align-items-center mx-0 mt-2">
            <input type="hidden" name="colorId" value="<%= col._id %>"/>

            <!-- Color Name -->
            <div class="col-md-4" style="padding-left: 0;">
              <input class="form-control col-md-4" name="colorName" placeholder="Color Name" required value="<%= col.name %>" />
            </div>

            <!-- Base Price -->
            <div class="col-md-3">
              <div class="input-group">
                <input class="form-control basePrice" name="colorPrice" placeholder="Base Price" type="number" min="0"
                required value="<%= col.basePrice %>" />
                <div class="input-group-text">
                  <input class="form-check-input mt-0 gstCheck" type="checkbox" name="colorGST"
                    <%= col.gstApplicable ? 'checked' : '' %> />
                  <small class="ms-1">GST</small>
                </div>
              </div>
            </div>

            <!-- Final Price (readonly) -->
            <div class="col-md-3">
              <input class="form-control finalPrice" type="text" placeholder="Final Price" value="<%= col.finalPrice ? col.finalPrice.toFixed(2) : '' %>" readonly />
            </div>

            <!-- Active -->
            <div class="col-6 col-md-1 d-flex align-items-md-center justify-content-md-center gap-1">
              <input class="form-check-input" type="checkbox" name="colorActive"
                <%= col.isActive ? 'checked' : '' %> />
              <label class="form-check-label">Active</label>
            </div>

            <!-- Delete -->
            <div class="col-6 col-md-1 text-end" style="padding-right: 0;">
              <% if (mode === 'edit') { %>
                <button type="button"
                  class="btn btn-outline-danger"
                  data-bs-toggle="modal"
                  data-bs-target="#deleteColorModal"
                  data-chair-id="<%= chair._id %>"
                  data-color-id="<%= col._id %>"
                  data-color-name="<%= col.name %>">
                  ✕
                </button>
              <% } else { %>
                <button type="button" class="btn btn-outline-danger removeColor">✕</button>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>

      <hr class="my-4">

      <div class="d-flex justify-content-between align-items-center mb-2">
        <h5 class="mb-0">Components</h5>
        <button type="button" id="addComponent" class="btn btn-sm btn-outline-primary">Add Component</button>
      </div>

      <div id="componentsContainer" class="vstack gap-2">
        <% (chair.components || []).forEach(component => { %>
          <div class="component-row row align-items-center mt-2" data-saved-id="<%= component.item %>">
            <div class="col-md-4">
              <select name="componentType" class="form-select" required>
                <option value="sparePart" <%= component.componentType === 'sparePart' ? 'selected' : '' %>>Spare Part</option>
                <option value="subAssembly" <%= component.componentType === 'subAssembly' ? 'selected' : '' %>>Sub Assembly</option>
              </select>
            </div>

            <div class="col-md-5">
              <select name="componentItem" class="form-select" required>
                <option value="">Select Item</option>
              </select>
            </div>

            <div class="col-md-2">
              <input type="number" name="componentQty" class="form-control" min="1" value="<%= component.quantity || 1 %>" required>
            </div>

            <div class="col-md-1 text-end">
              <button type="button" class="btn btn-outline-danger removeComponent">✕</button>
            </div>
          </div>
        <% }) %>
      </div>

      <div class="mt-4 d-flex justify-content-end">
        <button class="btn btn-primary"><%= mode === 'create' ? 'Create' : 'Save Changes' %></button>
      </div>
    </div>
  </form>
</div>

<!-- Delete Confirmation Modal -->
<div class="modal fade" id="deleteColorModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <form id="deleteColorForm" method="POST">
        <div class="modal-header">
          <h5 class="modal-title">Confirm Delete</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p>Are you sure you want to remove the color <strong id="deleteColorName"></strong>?</p>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-danger">Yes, Delete</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  const deleteModal = document.getElementById('deleteColorModal');
  const deleteForm = document.getElementById('deleteColorForm');
  const deleteColorName = document.getElementById('deleteColorName');

  deleteModal.addEventListener('show.bs.modal', event => {
    const button = event.relatedTarget;
    const chairId = button.getAttribute('data-chair-id');
    const colorId = button.getAttribute('data-color-id');
    const colorName = button.getAttribute('data-color-name');

    // Update form action
    deleteForm.action = `/raw-materials/chairs/${chairId}/colors/${colorId}/delete`;
    // Show color name in modal
    deleteColorName.textContent = colorName;
  });
</script>

<script>
  (function(){
    const container = document.getElementById('colorsContainer');
    const addBtn = document.getElementById('addColor');

    addBtn?.addEventListener('click', () => {
      const row = document.createElement('div');
      row.className = 'color-row row align-items-center mx-0 mt-2';
      row.innerHTML = `
        <div class="col-md-4" style="padding-left: 0;">
          <input class="form-control" name="colorName" placeholder="Color Name" required />
        </div>

        <div class="col-md-3">
          <div class="input-group">
            <input class="form-control basePrice" name="colorPrice" placeholder="Base Price" type="number" min="0" required />
            <div class="input-group-text">
              <input class="form-check-input mt-0 gstCheck" type="checkbox" name="colorGST" value="true" />
              <small class="ms-1">GST</small>
            </div>
          </div>
        </div>

        <div class="col-md-3">
          <input class="form-control finalPrice" type="text" placeholder="Final Price" readonly />
        </div>

        <div class="col-6 col-md-1 d-flex align-items-md-center justify-content-md-center gap-1">
          <input class="form-check-input" type="checkbox" name="colorActive" checked />
          <label class="form-check-label">Active</label>
        </div>

        <div class="col-6 col-md-1 text-end" style="padding-right: 0;">
          <button type="button" class="btn btn-outline-danger removeColor">✕</button>
        </div>
      `;
      container.appendChild(row);
    });

    container?.addEventListener('click', (e) => {
      if (e.target.classList.contains('removeColor')) {
        e.target.closest('.color-row')?.remove();
      }
    });
  })();
</script>

<script>
  function updateFinalPrice(row) {
    const base = Number(row.querySelector('.basePrice')?.value || 0);
    const gst = row.querySelector('.gstCheck')?.checked;
    const final = gst ? base * 1.18 : base;

    const finalInput = row.querySelector('.finalPrice');
    if (finalInput) finalInput.value = final.toFixed(2);
  }

  document.addEventListener('input', e => {
    const row = e.target.closest('.color-row');
    if (row) updateFinalPrice(row);
  });

  document.addEventListener('change', e => {
    const row = e.target.closest('.color-row');
    if (row) updateFinalPrice(row);
  });

  // Init on page load
  document.querySelectorAll('.color-row').forEach(updateFinalPrice);
</script>

<script>
  (function(){
    // Direct compilation injection of data lists from server payload variables
    const sparePartsList = <%- JSON.stringify(spareParts || []) %>;
    const subAssembliesList = <%- JSON.stringify(subAssemblies || []) %>;

    const container = document.getElementById('componentsContainer');
    const addBtn = document.getElementById('addComponent');

    // Helper engine to swap list contents inside the sub-selectors
    function populateItems(row, selectedType, preselectedId = '') {
      const itemSelect = row.querySelector('[name="componentItem"]');
      if (!itemSelect) return;

      itemSelect.innerHTML = '<option value="">Select Item</option>';
      const dataset = (selectedType === 'sparePart') ? sparePartsList : subAssembliesList;

      dataset.forEach(item => {
        const option = document.createElement('option');
        option.value = item._id;
        option.textContent = item.partName || item.name || 'Unnamed Item';
        if (String(item._id) === String(preselectedId)) {
          option.selected = true;
        }
        itemSelect.appendChild(option);
      });
    }

    // Trigger changes when dynamic row dropdown changes types
    container?.addEventListener('change', (e) => {
      if (e.target.name === 'componentType') {
        const row = e.target.closest('.component-row');
        populateItems(row, e.target.value);
      }
    });

    // Create New Row Event Handler
    addBtn?.addEventListener('click', () => {
      const row = document.createElement('div');
      row.className = 'component-row row align-items-center mt-2';
      row.innerHTML = `
        <div class="col-md-4">
          <select name="componentType" class="form-select" required>
            <option value="sparePart">Spare Part</option>
            <option value="subAssembly">Sub Assembly</option>
          </select>
        </div>
        <div class="col-md-5">
          <select name="componentItem" class="form-select" required>
            <option value="">Select Item</option>
          </select>
        </div>
        <div class="col-md-2">
          <input type="number" name="componentQty" class="form-control" value="1" min="1" required>
        </div>
        <div class="col-md-1 text-end">
          <button type="button" class="btn btn-outline-danger removeComponent">✕</button>
        </div>
      `;
      container.appendChild(row);
      populateItems(row, 'sparePart');
    });

    // Handle Item Row Deletions
    container?.addEventListener('click', (e) => {
      if (e.target.classList.contains('removeComponent')) {
        e.target.closest('.component-row')?.remove();
      }
    });

    // Rehydrate and build item dropdown loops for pre-existing items loaded in edit view
    document.querySelectorAll('.component-row').forEach(row => {
      const currentType = row.querySelector('[name="componentType"]')?.value;
      const savedItemId = row.getAttribute('data-saved-id');
      if (currentType) {
        populateItems(row, currentType, savedItemId);
      }
    });
  })();
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
