<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1"/>
  <title>Invoices - <%= pi.piNumber %></title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet"
  >
</head>

<body>
<%- include('../partials/navbar', { user, activePage }) %>

<div class="container py-5">

  <!-- ================= HEADER ================= -->
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h3 class="mb-0">Tax Invoices</h3>
      <small class="text-muted">
        Lead: <strong><%= lead.customer_name %></strong><br>
        PI: <strong><%= pi.piNumber %></strong>
      </small>
    </div>

    <div class="d-flex gap-2">
      <a
        href="/leads/<%= lead._id %>/pi"
        class="btn btn-outline-secondary"
      >
        ← Back to PI
      </a>

      <% if (pi.status !== 'DELETED' && canCreateInvoice) { %>
        <form
          method="POST"
          action="/leads/<%= lead._id %>/pi/<%= pi._id %>/invoices"
        >
          <button class="btn btn-danger">
            + Generate Invoice
          </button>
        </form>
      <% } %>
    </div>
  </div>

  <!-- ================= TABLE ================= -->
  <div class="card shadow-sm">
  <div class="card-body p-0">

    <% if (invoices.length) { %>
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Invoice No</th>
              <th>Version</th>
              <th>Date</th>
              <th class="text-end">Taxable</th>
              <th class="text-end">GST</th>
              <th class="text-end">Total</th>
              <th>GST Type</th>
              <th>Created By</th>
              <th class="text-end">Action</th>
            </tr>
          </thead>

          <tbody>
            <% invoices.forEach(inv => {
              const isDeleted = inv.status === 'DELETED';
            %>

              <tr class="<%= isDeleted ? 'text-muted' : '' %>">

                <td>
                  <%= inv.invoiceNumber %>
                  <% if (isDeleted) { %>
                    <span class="badge bg-danger ms-1">Deleted</span>
                  <% } %>
                </td>

                <td>
                  V<%= inv.invoiceSequence %>
                </td>

                <td>
                  <%= new Date(inv.createdAt).toLocaleDateString('en-IN') %>
                </td>

                <td class="text-end">
                  ₹<%= inv.taxableAmount.toLocaleString('en-IN') %>
                </td>

                <td class="text-end">
                  ₹<%= inv.gstAmount.toLocaleString('en-IN') %>
                </td>

                <td class="text-end">
                  ₹<%= inv.grandTotal.toLocaleString('en-IN') %>
                </td>

                <td>
                  <% if (inv.gstType === 'IGST') { %>
                    <span class="badge bg-warning text-dark">IGST</span>
                  <% } else if (inv.gstType === 'CGST_SGST') { %>
                    <span class="badge bg-info">CGST + SGST</span>
                  <% } else { %>
                    <span class="badge bg-secondary">No GST</span>
                  <% } %>
                </td>

                <td>
                  <%= inv.createdBy?.fullName || 'System' %>
                </td>

                <td class="text-end">
                  <div class="d-flex justify-content-end gap-2">

                    <a
                      href="/tax-invoice/<%= inv._id %>/pdf"
                      class="btn btn-sm btn-outline-success"
                      target="_blank"
                    >
                      PDF
                    </a>

                    <% if (user.role === 'admin' && !isDeleted) { %>
                      <button
                        type="button"
                        class="btn btn-sm btn-outline-danger"
                        data-bs-toggle="modal"
                        data-bs-target="#deleteInvoiceModal"
                        data-invoice-id="<%= inv._id %>"
                        data-invoice-number="<%= inv.invoiceNumber %>"
                      >
                        Delete
                      </button>
                    <% } %>

                  </div>
                </td>

              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } else { %>
      <div class="p-4 text-muted text-center">
        No tax invoices generated for this PI yet.
      </div>
    <% } %>

  </div>
</div>

</div>

<!-- ================= DELETE INVOICE MODAL ================= -->
<div class="modal fade" id="deleteInvoiceModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">

      <form id="deleteInvoiceForm" method="POST">

        <div class="modal-header">
          <h5 class="modal-title">Delete Tax Invoice</h5>
          <button class="btn-close" data-bs-dismiss="modal"></button>
        </div>

        <div class="modal-body">
          <p>
            Are you sure you want to delete
            <strong id="deleteInvoiceNumber"></strong>?
          </p>

          <div class="mb-3">
            <label class="form-label">Reason for deletion</label>
            <textarea
              name="deleteReason"
              class="form-control"
              rows="3"
              required
              placeholder="Mandatory for audit"
            ></textarea>
          </div>

          <p class="text-muted small mb-0">
            This action cannot be undone.
          </p>
        </div>

        <div class="modal-footer">
          <button class="btn btn-secondary" data-bs-dismiss="modal">
            Cancel
          </button>
          <button type="submit" class="btn btn-danger">
            Delete Invoice
          </button>
        </div>

      </form>

    </div>
  </div>
</div>

<!-- ================= SCRIPT ================= -->
<script>
const deleteModal = document.getElementById('deleteInvoiceModal');
const deleteForm = document.getElementById('deleteInvoiceForm');
const deleteInvoiceNumber = document.getElementById('deleteInvoiceNumber');

deleteModal.addEventListener('show.bs.modal', function (event) {
  const btn = event.relatedTarget;

  const invoiceId = btn.getAttribute('data-invoice-id');
  const invoiceNumber = btn.getAttribute('data-invoice-number');

  deleteInvoiceNumber.textContent = invoiceNumber;
  deleteForm.action = `/tax-invoice/${invoiceId}/delete`;
});
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
