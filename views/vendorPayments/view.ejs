<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>Payment Detail</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<%- include('../partials/navbar', { user, activePage }) %>

<div class="container py-5">

  <div class="card shadow-sm">
    <div class="card-body">

      <div class="d-flex justify-content-between align-items-center">
        <h4>Payment Details</h4>

        <span class="badge bg-success">
          Payment
        </span>
      </div>

      <!-- 🔥 AUDIT -->
      <div class="row g-3 mt-2">

        <div class="col-md-3">
          <small class="text-muted">Created By</small>
          <div><%= payment.createdBy?.name || '-' %></div>
        </div>

        <div class="col-md-3">
          <small class="text-muted">Created At</small>
          <div><%= new Date(payment.createdAt).toLocaleString('en-IN') %></div>
        </div>

        <div class="col-md-3">
          <small class="text-muted">Updated By</small>
          <div><%= payment.updatedBy?.name || '-' %></div>
        </div>

        <div class="col-md-3">
          <small class="text-muted">Updated At</small>
          <div><%= payment.updatedAt ? new Date(payment.updatedAt).toLocaleString('en-IN') : '-' %></div>
        </div>

      </div>

      <hr>

      <!-- 🔥 DETAILS -->
      <div class="row g-3">

        <div class="col-md-4">
          <small class="text-muted">Vendor</small>
          <div class="fw-semibold"><%= payment.vendor?.name %></div>
        </div>

        <div class="col-md-4">
          <small class="text-muted">Amount</small>
          <div class="fw-bold text-success">₹<%= payment.amount.toFixed(2) %></div>
        </div>

        <div class="col-md-4">
          <small class="text-muted">Date</small>
          <div><%= new Date(payment.paymentDate).toLocaleDateString('en-IN') %></div>
        </div>

        <div class="col-md-4">
          <small class="text-muted">Method</small>
          <div><%= payment.paymentMethod %></div>
        </div>

        <div class="col-md-4">
          <small class="text-muted">Reference</small>
          <div><%= payment.reference || '-' %></div>
        </div>

      </div>

      <hr>

      <h6>Notes</h6>

      <% if(payment.notes){ %>
        <div class="border rounded p-3 bg-light">
          <%= payment.notes %>
        </div>
      <% } else { %>
        <p class="text-muted">No notes added.</p>
      <% } %>

    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>