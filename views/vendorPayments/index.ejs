<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>Vendor Ledger</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<%- include('../partials/navbar', { user, activePage }) %>

<div class="container py-5">

  <div class="d-flex justify-content-between mb-3">
    <h4>Vendor Ledger</h4>
    <a href="/purchasing/vendor-payments/new" class="btn btn-primary">+ Add Payment</a>
  </div>

  <!-- 🔥 SUMMARY -->
  <%
    const totalDebit = ledger.reduce((s,l)=>s+l.debit,0);
    const totalCredit = ledger.reduce((s,l)=>s+l.credit,0);
    const finalBalance = totalDebit - totalCredit;
  %>

  <div class="row mb-3">
    <div class="col-md-4">
      <div class="card p-2 text-center shadow-sm">
        <small>Total Purchases</small>
        <div class="fw-bold text-danger">₹<%= totalDebit.toFixed(2) %></div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card p-2 text-center shadow-sm">
        <small>Total Payments</small>
        <div class="fw-bold text-success">₹<%= totalCredit.toFixed(2) %></div>
      </div>
    </div>

    <div class="col-md-4">
      <div class="card p-2 text-center shadow-sm">
        <small>Outstanding</small>
        <div class="fw-bold <%= finalBalance > 0 ? 'text-danger' : 'text-success' %>">
          ₹<%= finalBalance.toFixed(2) %>
        </div>
      </div>
    </div>
  </div>

  <!-- 🔥 TABLE -->
  <div class="table-responsive" style="max-height:70vh;">

    <table class="table table-bordered table-sm align-middle">

      <thead class="table-light sticky-top">
        <tr>
          <th>Date</th>
          <th>Type</th>
          <th>Vendor</th>
          <th>Ref</th>
          <th>Debit</th>
          <th>Credit</th>
          <th>Balance</th>
          <th class="text-end">Actions</th>
        </tr>
      </thead>

      <tbody>

        <% if(!ledger.length){ %>
          <tr>
            <td colspan="8" class="text-center text-muted">No transactions found</td>
          </tr>
        <% } %>

        <% ledger.forEach(l => { %>
          <tr>

            <td><%= new Date(l.date).toLocaleDateString('en-IN') %></td>

            <td>
              <span class="badge <%= l.type==='Purchase' ? 'bg-primary' : 'bg-success' %>">
                <%= l.type %>
              </span>
            </td>

            <td><%= l.vendor %></td>

            <td><%= l.ref %></td>

            <td class="text-danger">
              <%= l.debit ? '₹'+l.debit.toFixed(2) : '-' %>
            </td>

            <td class="text-success">
              <%= l.credit ? '₹'+l.credit.toFixed(2) : '-' %>
            </td>

            <td class="fw-bold <%= l.balance > 0 ? 'text-danger' : 'text-success' %>">
              ₹<%= l.balance.toFixed(2) %>
            </td>

            <td class="text-end">

              <% if(l.source==='payment'){ %>

                <a href="/purchasing/vendor-payments/<%= l.id %>" class="btn btn-sm btn-outline-secondary">View</a>

                <a href="/purchasing/vendor-payments/<%= l.id %>/edit" class="btn btn-sm btn-outline-primary">Edit</a>

                <form method="POST" action="/purchasing/vendor-payments/<%= l.id %>/delete" style="display:inline;">
                  <button class="btn btn-sm btn-outline-danger"
                    onclick="return confirm('Delete this payment?')">
                    Delete
                  </button>
                </form>

              <% } else { %>

                <a href="/purchasing/purchases/<%= l.id %>" class="btn btn-sm btn-outline-dark">View</a>

              <% } %>

            </td>

          </tr>
        <% }) %>

      </tbody>

    </table>

  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>