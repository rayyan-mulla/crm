<%
function displaySource(source) {
  const map = {
    google_sheet: "Google Sheets",
    meta: "Meta",
    indiamart: "IndiaMART",
    manual: "Manual Entry",
    excel_upload: "Excel Upload",
  };
  return map[source] || source;
}
%>

<% function formatDate(value) {
  if (!value) return '-';
  const d = new Date(value);
  if (isNaN(d)) return '-';
  const day = ('0' + d.getDate()).slice(-2);
  const month = ('0' + (d.getMonth() + 1)).slice(-2);
  const year = d.getFullYear();
  return `${day}/${month}/${year}`;
} %>

<!doctype html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Reports - Olive Chairs</title>

  <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css"
    rel="stylesheet"
  />
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css"
  />
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
    .chart-container {
      height: 300px;
    }
    .chart-wrapper {
      display: flex;
      justify-content: center;
      align-items: center;
      height: 250px;
    }
    .sticky-pagination {
      position: sticky;
      bottom: 0;
      background: #fff;
      padding: 0.5rem 0;
    }
  </style>
</head>

<body>
<%- include("../partials/navbar", { user, activePage }) %>

<div class="container py-5">
  <h3 class="mb-3">Sales Reports</h3>

  <!-- Global Filters -->
  <form method="get" action="/reports" class="mb-4">

    <div class="row g-3">

      <!-- Row 1 -->
      <div class="col-md-3">
        <input name="search"
          class="form-control form-control-sm"
          placeholder="Customer name"
          value="<%= query.search || '' %>">
      </div>

      <div class="col-md-3">
        <div class="input-group input-group-sm">
          <span class="input-group-text">From</span>
          <input
            type="date"
            name="fromDate"
            class="form-control"
            value="<%= query.fromDate || '' %>">
        </div>
      </div>

      <div class="col-md-3">
        <div class="input-group input-group-sm">
          <span class="input-group-text">To</span>
          <input
            type="date"
            name="toDate"
            class="form-control form-control-sm"
            value="<%= query.toDate || '' %>">
        </div>
      </div>

      <div class="col-md-3">
        <select name="assignedTo"
          class="form-select form-select-sm">
          <option value="">Assigned To</option>
          <% users.forEach(u => { %>
            <option value="<%= u._id %>"
              <%= String(query.assignedTo) === String(u._id) ? "selected" : "" %>>
              <%= u.fullName %>
            </option>
          <% }) %>
        </select>
      </div>

      <!-- Row 2 -->
      <div class="col-md-3">
        <select name="source"
          class="form-select form-select-sm">
          <option value="">Source</option>
          <option value="meta" <%= query.source === "meta" ? "selected" : "" %>>Meta</option>
          <option value="google_sheet" <%= query.source === "google_sheet" ? "selected" : "" %>>Google Sheet</option>
          <option value="manual" <%= query.source === "manual" ? "selected" : "" %>>Manual</option>
          <option value="excel_upload" <%= query.source === "excel_upload" ? "selected" : "" %>>Excel Upload</option>
          <option value="indiamart" <%= query.source === "indiamart" ? "selected" : "" %>>IndiaMART</option>
        </select>
      </div>

      <div class="col-md-3">
        <select name="model"
          class="form-select form-select-sm">
          <option value="">Chair Model</option>
          <% (allModels || []).forEach(m => { %>
            <option value="<%= m %>"
              <%= query.model === m ? "selected" : "" %>>
              <%= m %>
            </option>
          <% }) %>
        </select>
      </div>

      <!-- Show Analytics Toggle -->
      <div class="col-md-3 d-flex align-items-center">
        <div class="form-check">
          <input class="form-check-input"
            type="checkbox"
            name="showAnalytics"
            value="true"
            id="showAnalytics"
            <%= query.showAnalytics === "true" ? "checked" : "" %>>
          <label class="form-check-label" for="showAnalytics">
            Show Analytics
          </label>
        </div>
      </div>

      <!-- Buttons -->
      <div class="col-md-3 d-flex gap-2">
        <button type="submit"
          class="btn btn-primary btn-sm w-50">
          Apply
        </button>

        <button type="submit"
          formaction="/reports/pdf"
          formmethod="get"
          class="btn btn-danger btn-sm w-50">
          PDF
        </button>
      </div>

    </div>
  </form>

  <!-- KPI Advanced -->
  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card shadow-sm text-center">
        <div class="card-body">
          <h6>Avg Deal Value</h6>
          <h5 class="text-primary">₹<%= (summary.avgDealValue || 0).toLocaleString() %></h5>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm text-center">
        <div class="card-body">
          <h6>Avg Sell Price</h6>
          <h5 class="text-warning">₹<%= (summary.avgSellPrice || 0).toLocaleString() %></h5>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm text-center">
        <div class="card-body">
          <h6>Top Model</h6>
          <h5 class="text-info"><%= summary.topModel || "N/A" %></h5>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm text-center">
        <div class="card-body">
          <h6>Top Performer</h6>
          <h5 class="text-success"><%= summary.topUser || "N/A" %></h5>
        </div>
      </div>
    </div>
  </div>

  <!-- KPI Basic -->
  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card shadow-sm text-center">
        <div class="card-body">
          <h6>Total Revenue</h6>
          <h5 class="text-primary">₹<%= summary.totalRevenue.toLocaleString() %></h5>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm text-center">
        <div class="card-body">
          <h6>Total Profit</h6>
          <h5 class="text-success">₹<%= summary.totalProfit.toLocaleString() %></h5>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm text-center">
        <div class="card-body">
          <h6>Total Chairs</h6>
          <h5 class="text-warning"><%= summary.totalChairs %></h5>
        </div>
      </div>
    </div>

    <div class="col-md-3">
      <div class="card shadow-sm text-center">
        <div class="card-body">
          <h6>Deals</h6>
          <h5 class="text-info"><%= summary.totalDeals %></h5>
        </div>
      </div>
    </div>
  </div>

  <!-- Charts -->
  <% if (query.showAnalytics === "true") { %>
  <div class="row g-4 mb-4">
    <div class="col-md-6">
      <div class="card shadow-sm chart-container">
        <div class="card-body">
          <h6>Revenue vs Profit</h6>
          <div class="chart-wrapper">
            <canvas id="monthlyChart"></canvas>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card shadow-sm chart-container">
        <div class="card-body">
          <h6>Revenue by User</h6>
          <div class="chart-wrapper">
            <canvas id="userChart"></canvas>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card shadow-sm chart-container">
        <div class="card-body">
          <h6>Chairs Sold</h6>
          <div class="chart-wrapper">
            <canvas id="chairChart"></canvas>
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card shadow-sm chart-container">
        <div class="card-body">
          <h6>Revenue by Source</h6>
          <div class="chart-wrapper">
            <canvas id="sourceChart"></canvas>
          </div>
        </div>
      </div>
    </div>
  </div>
  <% } %>
  <!-- Sticky per page -->
  <div class="sticky-pagination mb-2">
    <form 
      class="d-flex align-items-center gap-2" 
      method="get" 
      action="/reports"
    >
      <span class="small mb-0">Per page</span>

      <!-- Preserve filters -->
      <input type="hidden" name="search" value="<%= query.search || '' %>">
      <input type="hidden" name="fromDate" value="<%= query.fromDate || '' %>">
      <input type="hidden" name="toDate" value="<%= query.toDate || '' %>">
      <input type="hidden" name="assignedTo" value="<%= query.assignedTo || '' %>">
      <input type="hidden" name="source" value="<%= query.source || '' %>">
      <input type="hidden" name="model" value="<%= query.model || '' %>">
      <input type="hidden" name="showAnalytics" value="<%= query.showAnalytics || '' %>">

      <input type="hidden" name="page" value="1">

      <select 
        name="limit" 
        class="form-select form-select-sm" 
        style="width:auto; min-width:80px;"
        onchange="this.form.submit()"
      >
        <option value="10"  <%= +limit === 10  ? 'selected' : '' %>>10</option>
        <option value="25"  <%= +limit === 25  ? 'selected' : '' %>>25</option>
        <option value="50"  <%= +limit === 50  ? 'selected' : '' %>>50</option>
        <option value="100" <%= +limit === 100 ? 'selected' : '' %>>100</option>
      </select>
    </form>
  </div>
  <!-- Table -->
  <div class="card shadow-sm">
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-sm table-hover align-middle">
          <thead class="table-light">
            <tr>
              <th>Date</th>
              <th>Customer</th>
              <th>User</th>
              <th>Chair</th>
              <th>Color</th>
              <th>Qty</th>
              <th>Sell</th>
              <th>Cost</th>
              <th>Profit</th>
              <th>Source</th>
            </tr>
          </thead>

          <tbody>
            <% rows.forEach(r => { %>
              <tr>
                <td><%= formatDate(r.date) %></td>
                <td><%= r.customer %></td>
                <td><%= r.user %></td>
                <td><%= r.chair %></td>
                <td><%= r.color %></td>
                <td><%= r.qty %></td>
                <td class="text-primary">₹<%= r.sellUnit %></td>
                <td>₹<%= r.costUnit %></td>
                <td class="<%= r.profit >= 0 ? 'text-success' : 'text-danger' %> fw-bold">
                  ₹<%= Number(r.profit || 0).toLocaleString('en-IN', { maximumFractionDigits: 2 }) %>
                </td>
                <td>
                  <span class="badge bg-light border text-dark">
                    <%= displaySource(r.source) %>
                  </span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <!-- Pagination -->
      <div class="sticky-pagination mt-2">
        <nav aria-label="report-pagination">
          <ul class="pagination justify-content-center flex-nowrap">

            <%
              function buildQuery(pageNum) {
                let qs = `?page=${pageNum}&limit=${limit}`;
                if (query.search)        qs += `&search=${encodeURIComponent(query.search)}`;
                if (query.fromDate)      qs += `&fromDate=${encodeURIComponent(query.fromDate)}`;
                if (query.toDate)        qs += `&toDate=${encodeURIComponent(query.toDate)}`;
                if (query.assignedTo)    qs += `&assignedTo=${encodeURIComponent(query.assignedTo)}`;
                if (query.source)        qs += `&source=${encodeURIComponent(query.source)}`;
                if (query.model)         qs += `&model=${encodeURIComponent(query.model)}`;
                if (query.showAnalytics) qs += `&showAnalytics=${encodeURIComponent(query.showAnalytics)}`;
                return qs;
              }
            %>

            <!-- Previous -->
            <li class="page-item <%= page === 1 ? 'disabled' : '' %>">
              <a class="page-link" href="<%= buildQuery(Math.max(1, page - 1)) %>">&laquo;</a>
            </li>

            <!-- First -->
            <li class="page-item <%= page === 1 ? 'active' : '' %>">
              <a class="page-link" href="<%= buildQuery(1) %>">1</a>
            </li>

            <%
              const slots = 3;
              let centerStart = page - 1;
              let centerEnd   = page + 1;

              if (centerStart < 2) {
                centerStart = 2;
                centerEnd = centerStart + slots - 1;
              }

              if (centerEnd > totalPages - 1) {
                centerEnd = totalPages - 1;
                centerStart = centerEnd - slots + 1;
              }

              centerStart = Math.max(2, centerStart);
              centerEnd   = Math.min(totalPages - 1, centerEnd);
            %>

            <!-- Left Ellipsis -->
            <% if (centerStart > 2) { %>
              <li class="page-item disabled">
                <span class="page-link">…</span>
              </li>
            <% } %>

            <!-- Center Pages -->
            <% for (let p = centerStart; p <= centerEnd; p++) { %>
              <li class="page-item <%= p === page ? 'active' : '' %>">
                <a class="page-link" href="<%= buildQuery(p) %>"><%= p %></a>
              </li>
            <% } %>

            <!-- Right Ellipsis -->
            <% if (centerEnd < totalPages - 1) { %>
              <li class="page-item disabled">
                <span class="page-link">…</span>
              </li>
            <% } %>

            <!-- Last -->
            <% if (totalPages > 1) { %>
              <li class="page-item <%= page === totalPages ? 'active' : '' %>">
                <a class="page-link" href="<%= buildQuery(totalPages) %>"><%= totalPages %></a>
              </li>
            <% } %>

            <!-- Next -->
            <li class="page-item <%= page === totalPages ? 'disabled' : '' %>">
              <a class="page-link" href="<%= buildQuery(Math.min(totalPages, page + 1)) %>">&raquo;</a>
            </li>

          </ul>
        </nav>
      </div>
    </div>
  </div>
</div>

<script>
  const COLORS = [
    "#0d6efd","#ffc107","#0dcaf0",
    "#6f42c1","#198754","#dc3545","#6c757d"
  ];

  const monthly   = <%- JSON.stringify(charts.monthly || {}) %>;
  const userData  = <%- JSON.stringify(charts.revenueByUser || {}) %>;
  const chairData = <%- JSON.stringify(charts.chairsByModel || {}) %>;
  const sourceData= <%- JSON.stringify(charts.revenueBySource || {}) %>;

  function destroyIfExists(name){
    if(window[name]) window[name].destroy();
  }

  destroyIfExists("monthlyChartInstance");
  window.monthlyChartInstance =
  new Chart(document.getElementById("monthlyChart"),{
    type:"line",
    data:{
      labels:Object.keys(monthly),
      datasets:[
        {
          label:"Revenue",
          data:Object.values(monthly).map(m=>m.revenue),
          borderColor:"#0d6efd",
          tension:0.3
        },
        {
          label:"Profit",
          data:Object.values(monthly).map(m=>m.profit),
          borderColor:"#198754",
          tension:0.3
        }
      ]
    }
  });

  destroyIfExists("userChartInstance");
  window.userChartInstance =
  new Chart(document.getElementById("userChart"),{
    type:"doughnut",
    data:{
      labels:Object.keys(userData),
      datasets:[{
        data:Object.values(userData),
        backgroundColor:COLORS
      }]
    },
    options: {
      maintainAspectRatio: false,
      cutout: "60%"
    }
  });

  destroyIfExists("chairChartInstance");
  window.chairChartInstance =
  new Chart(document.getElementById("chairChart"),{
    type:"doughnut",
    data:{
      labels:Object.keys(chairData),
      datasets:[{
        data:Object.values(chairData),
        backgroundColor:COLORS
      }]
    },
    options: {
      maintainAspectRatio: false,
      cutout: "60%"
    }
  });

  destroyIfExists("sourceChartInstance");
  window.sourceChartInstance =
  new Chart(document.getElementById("sourceChart"),{
    type:"bar",
    data:{
      labels:Object.keys(sourceData),
      datasets:[{
        label:"Revenue",
        data:Object.values(sourceData),
        backgroundColor:"#0d6efd"
      }]
    }
  });
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>