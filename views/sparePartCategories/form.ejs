<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>
    <%= mode === 'create' ? 'Add Category' : 'Edit Category' %> - Olive Chairs ERP
  </title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<%- include('../partials/navbar', { user, activePage }) %>

<div class="container py-5">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h3>
      <%= mode === 'create' ? 'Add Category' : 'Edit Category' %>
    </h3>
  </div>

  <form
    action="<%= mode === 'create'
      ? '/raw-materials/spare-part-categories'
      : '/raw-materials/spare-part-categories/' + category._id %>"
    method="post"
    class="card shadow-sm p-3"
  >

    <div class="card-body">

      <div class="row g-3">

        <!-- Category Name -->
        <div class="col-md-8">
          <label class="form-label">Category Name</label>

          <input
            name="name"
            class="form-control"
            required
            value="<%= category.name || '' %>"
          >
        </div>

        <!-- Active -->
        <div class="col-md-4 d-flex align-items-end">

          <div class="form-check mt-4">

            <input
              class="form-check-input"
              type="checkbox"
              name="isActive"
              id="isActive"
              <%= mode === 'create'
                    ? 'checked'
                    : (category.isActive ? 'checked' : '') %>
            >

            <label class="form-check-label" for="isActive">
              Active
            </label>

          </div>

        </div>

      </div>

      <div class="mt-4 d-flex justify-content-end">

        <button class="btn btn-primary">
          <%= mode === 'create' ? 'Create' : 'Save Changes' %>
        </button>

      </div>

    </div>

  </form>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>